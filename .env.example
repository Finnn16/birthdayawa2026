# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Prisma migration connection string
DATABASE_URL=postgresql://postgres:password@host:5432/postgres

# Twilio Configuration (for WhatsApp notifications)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_PHONE_NUMBER=+1234567890

# Notification API Security
NOTIFICATION_API_KEY=your_secure_notification_api_key
CRON_SECRET=your_cron_secret

# AI Hero Message Generation
GEMINI_API_KEY=your_gemini_api_key
AI_HERO_GEMINI_MODELS=gemini-2.5-flash-lite,gemini-2.0-flash-lite,gemini-2.0-flash,gemini-2.5-flash
AI_HERO_TIMEOUT_MS=12000
