generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id                         String               @id @db.Uuid
  username                   String               @unique
  createdAt                  DateTime?            @default(now()) @map("created_at") @db.Timestamptz(6)
  email                      String?
  phoneNumber                String?              @map("phone_number")
  reminderEnabled            Boolean?             @default(true) @map("reminder_enabled")
  lastMoodReminderSentAt     DateTime?            @map("last_mood_reminder_sent_at") @db.Timestamptz(6)
  lastMinigameReminderSentAt DateTime?            @map("last_minigame_reminder_sent_at") @db.Timestamptz(6)
  role                       String?              @default("user")
  moods                      Mood[]
  xpTransactions             XpTransaction[]
  miniGameCompletions        MiniGameCompletion[]
  miniGamesCreated           MiniGame[]           @relation("MiniGameCreator")
  heartTransactions          HeartTransaction[]   @relation("HeartTransactionUser")
  heartTransactionsCreated   HeartTransaction[]   @relation("HeartTransactionCreator")
  rewardRedemptions          RewardRedemption[]
  rewardsCreated             Reward[]             @relation("RewardCreator")
  questBankCreated           DailyQuestBank[]      @relation("DailyQuestCreator")
  questAssignmentsCreated    DailyQuestAssignment[] @relation("DailyQuestAssigner")
  questCompletions           DailyQuestCompletion[]
  inventory                  UserInventory[]
  streakProtectionLogs       StreakProtectionLog[]
  gardenItems                GardenItem[]
  coupleEventsCreated        CoupleEvent[]         @relation("CoupleEventCreator")
  heroMessagesCreated        HeroMessage[]          @relation("HeroMessageCreator")
  notificationCampaignsCreated NotificationCampaign[] @relation("NotificationCampaignCreator")
  notificationDeliveryLogs    NotificationDeliveryLog[]

  @@index([phoneNumber])
  @@map("users")
}

model Response {
  id        Int       @id @default(autoincrement())
  rangeMin  Int       @map("range_min")
  rangeMax  Int       @map("range_max")
  message   String
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("responses")
}

model Mood {
  id        String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  date      DateTime  @default(dbgenerated("CURRENT_DATE")) @db.Date
  rating    Int
  note      String?
  xpEarned  Int       @default(10) @map("xp_earned")
  streakDay Int       @default(1) @map("streak_day")
  createdAt DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date], map: "moods_user_date_unique")
  @@index([userId, date(sort: Desc)], map: "moods_user_id_date_idx")
  @@map("moods")
}

model XpTransaction {
  id         String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId     String    @map("user_id") @db.Uuid
  sourceType String    @map("source_type")
  sourceId   String?   @map("source_id") @db.Uuid
  xpAmount   Int       @map("xp_amount")
  multiplier Decimal   @default(1) @db.Decimal(4, 2)
  finalXp    Int       @map("final_xp")
  createdAt  DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@map("xp_transactions")
}

model LevelConfig {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  levelNumber     Int       @unique @map("level_number")
  levelName       String    @map("level_name")
  requiredTotalXp Int       @unique @map("required_total_xp")
  createdAt       DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("level_configs")
}

model MiniGame {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title       String
  description String?
  type        String
  difficulty  String
  xpReward    Int                  @map("xp_reward")
  heartsReward Int                 @default(0) @map("hearts_reward")
  activeDate  DateTime?            @map("active_date") @db.Date
  isActive    Boolean              @default(false) @map("is_active")
  prompt      String?
  optionsJson Json?                @map("options_json")
  correctAnswer String?            @map("correct_answer")
  metadataJson Json?               @map("metadata_json")
  publishStatus String             @default("draft") @map("publish_status")
  publishAt   DateTime?            @map("publish_at") @db.Timestamptz(6)
  publishedAt DateTime?            @map("published_at") @db.Timestamptz(6)
  archivedAt  DateTime?            @map("archived_at") @db.Timestamptz(6)
  createdBy   String?              @map("created_by") @db.Uuid
  createdAt   DateTime?            @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime?            @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  creator     User?                @relation("MiniGameCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  completions MiniGameCompletion[]

  @@index([isActive, activeDate])
  @@index([publishStatus, publishAt])
  @@map("mini_games")
}

model MiniGameCompletion {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  minigameId   String    @map("minigame_id") @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  isCorrect    Boolean   @default(false) @map("is_correct")
  xpEarned     Int       @default(0) @map("xp_earned")
  heartsEarned Int       @default(0) @map("hearts_earned")
  completedAt  DateTime? @default(now()) @map("completed_at") @db.Timestamptz(6)
  metadataJson Json?     @map("metadata_json")
  minigame     MiniGame  @relation(fields: [minigameId], references: [id], onDelete: Cascade)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([minigameId, userId])
  @@index([userId, completedAt(sort: Desc)])
  @@map("mini_game_completions")
}

model HeartTransaction {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  sourceType   String    @map("source_type")
  sourceId     String?   @map("source_id") @db.Uuid
  amount       Int
  note         String?
  metadataJson Json?     @map("metadata_json")
  createdBy    String?   @map("created_by") @db.Uuid
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User      @relation("HeartTransactionUser", fields: [userId], references: [id], onDelete: Cascade)
  creator      User?     @relation("HeartTransactionCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([userId, createdAt(sort: Desc)])
  @@map("heart_transactions")
}

model Reward {
  id                    String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title                 String             @unique
  description           String?
  costHearts            Int                @map("cost_hearts")
  category              String             @default("experience")
  isActive              Boolean            @default(true) @map("is_active")
  requiresAdminApproval Boolean            @default(true) @map("requires_admin_approval")
  stockLimit            Int?               @map("stock_limit")
  metadataJson          Json?              @map("metadata_json")
  publishStatus         String             @default("draft") @map("publish_status")
  publishAt             DateTime?          @map("publish_at") @db.Timestamptz(6)
  publishedAt           DateTime?          @map("published_at") @db.Timestamptz(6)
  archivedAt            DateTime?          @map("archived_at") @db.Timestamptz(6)
  createdBy             String?            @map("created_by") @db.Uuid
  createdAt             DateTime?          @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt             DateTime?          @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  creator               User?              @relation("RewardCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  redemptions           RewardRedemption[]

  @@index([isActive, category])
  @@index([publishStatus, publishAt])
  @@map("rewards")
}

model RewardRedemption {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  rewardId    String    @map("reward_id") @db.Uuid
  userId      String    @map("user_id") @db.Uuid
  status      String    @default("pending")
  costHearts  Int       @map("cost_hearts")
  note        String?
  adminNote   String?   @map("admin_note")
  requestedAt DateTime? @default(now()) @map("requested_at") @db.Timestamptz(6)
  approvedAt  DateTime? @map("approved_at") @db.Timestamptz(6)
  fulfilledAt DateTime? @map("fulfilled_at") @db.Timestamptz(6)
  updatedAt   DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  reward      Reward    @relation(fields: [rewardId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, requestedAt(sort: Desc)])
  @@index([status, requestedAt(sort: Desc)])
  @@map("reward_redemptions")
}

model DailyQuestBank {
  id             String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title          String                 @unique
  description    String?
  type           String                 @default("reflection")
  difficulty     String                 @default("easy")
  xpReward       Int                    @default(0) @map("xp_reward")
  heartsReward   Int                    @default(0) @map("hearts_reward")
  prompt         String?
  optionsJson    Json?                  @map("options_json")
  correctAnswer  String?                @map("correct_answer")
  isActive       Boolean                @default(true) @map("is_active")
  metadataJson   Json?                  @map("metadata_json")
  publishStatus  String                 @default("draft") @map("publish_status")
  publishAt      DateTime?              @map("publish_at") @db.Timestamptz(6)
  publishedAt    DateTime?              @map("published_at") @db.Timestamptz(6)
  archivedAt     DateTime?              @map("archived_at") @db.Timestamptz(6)
  createdBy      String?                @map("created_by") @db.Uuid
  createdAt      DateTime?              @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime?              @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  creator        User?                  @relation("DailyQuestCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  assignments    DailyQuestAssignment[]
  completions    DailyQuestCompletion[]

  @@index([isActive, type])
  @@index([publishStatus, publishAt])
  @@map("daily_quest_bank")
}

model DailyQuestAssignment {
  id          String                 @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  questId     String                 @map("quest_id") @db.Uuid
  activeDate  DateTime               @map("active_date") @db.Date
  isActive    Boolean                @default(true) @map("is_active")
  assignedBy  String?                @map("assigned_by") @db.Uuid
  createdAt   DateTime?              @default(now()) @map("created_at") @db.Timestamptz(6)
  quest       DailyQuestBank         @relation(fields: [questId], references: [id], onDelete: Cascade)
  assigner    User?                  @relation("DailyQuestAssigner", fields: [assignedBy], references: [id], onDelete: SetNull)
  completions DailyQuestCompletion[]

  @@unique([questId, activeDate])
  @@index([isActive, activeDate(sort: Desc)])
  @@map("daily_quest_assignments")
}

model DailyQuestCompletion {
  id           String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  assignmentId String               @map("assignment_id") @db.Uuid
  questId      String               @map("quest_id") @db.Uuid
  userId       String               @map("user_id") @db.Uuid
  activeDate   DateTime             @map("active_date") @db.Date
  answer       String?
  isCorrect    Boolean              @default(true) @map("is_correct")
  xpEarned     Int                  @default(0) @map("xp_earned")
  heartsEarned Int                  @default(0) @map("hearts_earned")
  completedAt  DateTime?            @default(now()) @map("completed_at") @db.Timestamptz(6)
  metadataJson Json?                @map("metadata_json")
  assignment   DailyQuestAssignment @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  quest        DailyQuestBank       @relation(fields: [questId], references: [id], onDelete: Cascade)
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([assignmentId, userId])
  @@index([userId, activeDate(sort: Desc)])
  @@map("daily_quest_completions")
}

model UserInventory {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  itemType     String    @map("item_type")
  quantity     Int       @default(0)
  sourceType   String    @default("admin_grant") @map("source_type")
  metadataJson Json?     @map("metadata_json")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, itemType])
  @@map("user_inventory")
}

model StreakProtectionLog {
  id                String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId            String    @map("user_id") @db.Uuid
  itemType          String    @map("item_type")
  protectedDate     DateTime  @map("protected_date") @db.Date
  reason            String?
  status            String    @default("approved")
  requestedAt       DateTime? @default(now()) @map("requested_at") @db.Timestamptz(6)
  approvedAt        DateTime? @map("approved_at") @db.Timestamptz(6)
  reviewedBy        String?   @map("reviewed_by") @db.Uuid
  adminNote         String?   @map("admin_note")
  previousStreakDay Int?      @map("previous_streak_day")
  createdAt         DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  user              User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, protectedDate])
  @@index([status, requestedAt(sort: Desc)])
  @@map("streak_protection_logs")
}

model GardenItem {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String    @map("user_id") @db.Uuid
  sourceType   String    @map("source_type")
  sourceId     String?   @map("source_id") @db.Uuid
  itemType     String    @map("item_type")
  moodRating   Int?      @map("mood_rating")
  earnedDate   DateTime  @default(dbgenerated("CURRENT_DATE")) @map("earned_date") @db.Date
  metadataJson Json?     @map("metadata_json")
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, earnedDate(sort: Desc)])
  @@map("garden_items")
}

model CoupleEvent {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  description  String?
  eventDate    DateTime  @map("event_date") @db.Date
  eventType    String    @default("custom") @map("event_type")
  visibility   String    @default("both")
  isSpecial    Boolean   @default(false) @map("is_special")
  isActive     Boolean   @default(true) @map("is_active")
  metadataJson Json?     @map("metadata_json")
  createdBy    String?   @map("created_by") @db.Uuid
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  creator      User?     @relation("CoupleEventCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([eventDate(sort: Desc), isActive])
  @@map("couple_events")
}

model HeroMessage {
  id           String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  body         String
  tone         String    @default("soft")
  activeDate   DateTime? @map("active_date") @db.Date
  isActive     Boolean   @default(true) @map("is_active")
  metadataJson Json?     @map("metadata_json")
  publishStatus String   @default("draft") @map("publish_status")
  publishAt    DateTime? @map("publish_at") @db.Timestamptz(6)
  publishedAt  DateTime? @map("published_at") @db.Timestamptz(6)
  archivedAt   DateTime? @map("archived_at") @db.Timestamptz(6)
  createdBy    String?   @map("created_by") @db.Uuid
  createdAt    DateTime? @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime? @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  creator      User?     @relation("HeroMessageCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([isActive, activeDate(sort: Desc), createdAt(sort: Desc)])
  @@index([publishStatus, publishAt])
  @@map("hero_messages")
}

model NotificationCampaign {
  id               String                    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String
  notificationType String                    @map("notification_type")
  triggerType      String                    @map("trigger_type")
  sendTime         String                    @map("send_time")
  startDate        DateTime?                 @map("start_date") @db.Date
  endDate          DateTime?                 @map("end_date") @db.Date
  timezone         String                    @default("Asia/Jakarta")
  publishStatus    String                    @default("published") @map("publish_status")
  publishAt        DateTime?                 @map("publish_at") @db.Timestamptz(6)
  isActive         Boolean                   @default(true) @map("is_active")
  metadataJson     Json?                     @map("metadata_json")
  lastSentAt       DateTime?                 @map("last_sent_at") @db.Timestamptz(6)
  createdBy        String?                   @map("created_by") @db.Uuid
  createdAt        DateTime?                 @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime?                 @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  creator          User?                     @relation("NotificationCampaignCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  messages         NotificationMessage[]
  deliveryLogs     NotificationDeliveryLog[]

  @@index([isActive, triggerType, sendTime])
  @@index([publishStatus, publishAt])
  @@map("notification_campaigns")
}

model NotificationMessage {
  id         String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId String               @map("campaign_id") @db.Uuid
  title      String
  body       String
  weight     Int                  @default(1)
  isActive   Boolean              @default(true) @map("is_active")
  createdAt  DateTime?            @default(now()) @map("created_at") @db.Timestamptz(6)
  campaign   NotificationCampaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, isActive])
  @@map("notification_messages")
}

model NotificationDeliveryLog {
  id                  String                @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId          String?               @map("campaign_id") @db.Uuid
  userId              String?               @map("user_id") @db.Uuid
  notificationTitle   String                @map("notification_title")
  notificationBody    String                @map("notification_body")
  status              String                @default("pending")
  deliveryChannel     String                @default("whatsapp") @map("delivery_channel")
  providerMessageId   String?               @map("provider_message_id")
  errorMessage        String?               @map("error_message")
  sentAt              DateTime?             @map("sent_at") @db.Timestamptz(6)
  deliveredAt         DateTime?             @map("delivered_at") @db.Timestamptz(6)
  createdAt           DateTime?             @default(now()) @map("created_at") @db.Timestamptz(6)
  campaign            NotificationCampaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  user                User?                 @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([campaignId, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@index([status, createdAt(sort: Desc)])
  @@map("notification_delivery_logs")
}
